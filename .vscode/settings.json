{
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "[markdown]": {
    "files.trimTrailingWhitespace": false,
    "editor.formatOnSave": true
  },
  "editor.rulers": [
    100
  ],
  "files.associations": {
    "*.agent.md": "chatagent",
    "*.instructions.md": "instructions",
    "*.prompt.md": "prompt"
  },
  "yaml.schemas": {
    "./.schemas/collection.schema.json": "*.collection.yml",
    "./.schemas/tools.schema.json": "website/data/tools.yml",
  },
  "chat.mcp.serverSampling": {
    "awesome-copilot/.vscode/mcp.json: github-agentic-workflows": {
      "allowedModels": [
        "copilot/auto",
        "copilot/claude-haiku-4.5",
        "copilotcli/claude-haiku-4.5",
        "claude-code/claude-haiku-4.5",
        "copilotcli/gpt-4.1",
        "copilot/gpt-5-mini",
        "copilotcli/gpt-5-mini",
        "copilot/oswe-vscode-prime"
      ]
    }
  }
}
