{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": ".github/hooks/work-log-tracker/log-session-start.sh",
        "cwd": ".",
        "timeoutSec": 5
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": ".github/hooks/work-log-tracker/log-session-end.sh",
        "cwd": ".",
        "timeoutSec": 5
      }
    ]
  }
}
