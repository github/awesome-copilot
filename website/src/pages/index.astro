---
/**
 * Homepage — ported from awesome-copilot-jh base UI.
 *
 * Renders HeroSection, CTASection, and FaqSection from base visual shell.
 * Resource cards and search preview are wired to upstream manifest/search data.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import CTASection from '../components/sections/CTASection.astro';
import FaqSection from '../components/sections/FaqSection.astro';
import ContributorsSection from '../components/sections/ContributorsSection.astro';
import { SITE } from '../config/site';
import { adaptManifest, type ManifestSummary } from '../lib/adapters/manifest';
import { adaptSearchIndex, type SearchResultEntry } from '../lib/adapters/search';
import manifestData from '../../public/data/manifest.json';
import searchIndexData from '../../public/data/search-index.json';
import type { ManifestItem, SearchIndexData } from '../lib/upstream-types';

const manifest: ManifestSummary = adaptManifest(manifestData as ManifestItem);
const searchEntries: SearchResultEntry[] = adaptSearchIndex(searchIndexData as SearchIndexData);
---
<BaseLayout
  title={`${SITE.title} · GitHub Copilot resource console`}
  description={SITE.description}
>
  <HeroSection
    resources={manifest.cards}
    searchEntries={searchEntries}
  />

  <CTASection />

  <FaqSection />

  <ContributorsSection />
</BaseLayout>

<!-- Embedded data for client scripts ─────── -->
<script type="application/json" id="embedded-search-data">
  {JSON.stringify(searchEntries).replace(/</g, '\\u003c')}
</script>

<script>
  import { initSearch, createSearch } from '../scripts/search-client';
  import type { SearchResultEntry as Entry } from '../lib/adapters/search';

  /* ── Typed reference to embedded data ──── */
  const dataEl = document.getElementById('embedded-search-data');
  if (!dataEl || !dataEl.textContent) {
    throw new Error('Search data not found');
  }

  const entries: Entry[] = JSON.parse(dataEl.textContent) as Entry[];

  interface GlobalSearchItem {
    title: string;
    description: string;
    searchText: string;
    tags: string[];
    route: string;
    label: string;
    path: string;
  }

  const items: GlobalSearchItem[] = entries.map((e) => ({
    title: e.title,
    description: e.description,
    searchText: e.searchText,
    tags: e.tags,
    route: e.route,
    label: e.label,
    path: e.path,
  }));

  const engine = createSearch<GlobalSearchItem>(items);

  initSearch<GlobalSearchItem>(engine, {
    inputSelector: '#global-search',
    resultsSelector: '#global-search-results',
    statusSelector: '#global-search-status',
    minLength: 2,
    maxResults: 40,
  }, {
    render(item, idx, _query, highlight) {
      const title = highlight(item.title, _query);
      const desc = highlight(
        item.description.length > 120
          ? `${item.description.slice(0, 120)}…`
          : item.description,
        _query,
      );
      return `
        <div class="search-result" data-result-index="${idx}" role="option" aria-selected="false">
          <span class="search-result-label">${item.label}</span>
          <span class="search-result-title">${title}</span>
          <span class="search-result-desc">${desc}</span>
        </div>`;
    },
    onSelect(item) {
      const hash = item.path ? `#file=${encodeURIComponent(item.path)}` : '';
      window.location.href = `${item.route}${hash}`;
    },
    statusText(query, resultCount, totalCount) {
      if (!query) return '';
      if (resultCount === 0) return `No results for "${query}"`;
      return `${resultCount} of ${totalCount} results for "${query}"`;
    },
  });
</script>

<style is:global>
  /* ── Global search result styles (for nav search bar) ── */
  #global-search-results {
    position: absolute;
    inset: 100% 0 auto;
    z-index: 5;
    max-height: 420px;
    overflow-y: auto;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2);
    background: var(--color-bg-elevated);
    box-shadow: var(--shadow-card);
  }

  .search-result {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--color-border-soft);
    cursor: pointer;
    transition: background var(--motion-fast);
  }

  .search-result:last-child {
    border-bottom: none;
  }

  .search-result:hover,
  .search-result--active {
    background: var(--color-surface-2);
  }

  .search-result-label {
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary);
    padding: 0.1rem 0.4rem;
    border: 1px solid var(--color-primary);
    border-radius: var(--radius-1);
  }

  .search-result-title {
    font-weight: 700;
    font-family: var(--font-heading);
    font-size: 0.92rem;
    color: var(--color-text);
  }

  .search-result-desc {
    width: 100%;
    font-size: 0.78rem;
    color: var(--color-muted);
    margin-top: 0.15rem;
  }

  .search-result mark {
    background: var(--color-primary);
    color: var(--color-black);
    padding: 0 0.15rem;
    border-radius: 2px;
  }

  @media (max-width: 640px) {
    #global-search-results {
      position: relative;
      inset: auto;
      margin-top: 0.5rem;
      max-height: 320px;
    }
  }
</style>
