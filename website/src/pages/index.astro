---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import Modal from "../components/Modal.astro";
import BackToTop from "../components/BackToTop.astro";
import CommunityCTA from "../components/home/CommunityCTA.astro";
import Hero from "../components/home/Hero.astro";
import HowItWorks from "../components/home/HowItWorks.astro";
import InstallCard from "../components/home/InstallCard.astro";
import QuickLinks from "../components/home/QuickLinks.astro";

const base = import.meta.env.BASE_URL;

const categories = [
  {
    title: "Code smarter",
    description: "Make Copilot write, review, and reason like a domain expert for your stack.",
    items: [
      {
        id: "agents",
        icon: "robot" as const,
        title: "Agents",
        description: "Specialized personas for complex domains — .NET, AWS, accessibility, security, and more.",
        path: "agents/",
        accentClass: "card-category-ai",
        countKey: "agents",
      },
      {
        id: "skills",
        icon: "lightning" as const,
        title: "Skills",
        description: "Reusable folders of instructions and bundled assets for multi-step tasks.",
        path: "skills/",
        accentClass: "card-category-power",
        countKey: "skills",
      },
      {
        id: "instructions",
        icon: "document" as const,
        title: "Instructions",
        description: "Coding standards and conventions applied automatically by file pattern.",
        path: "instructions/",
        accentClass: "card-category-docs",
        countKey: "instructions",
      },
    ],
  },
  {
    title: "Automate workflows",
    description: "Orchestrate sessions, toolkits, and CI/CD with Copilot.",
    items: [
      {
        id: "plugins",
        icon: "plug" as const,
        title: "Plugins",
        description: "Curated bundles of agents, skills, and commands for the Copilot CLI.",
        path: "plugins/",
        accentClass: "card-category-extension",
        countKey: "plugins",
      },
      {
        id: "hooks",
        icon: "hook" as const,
        title: "Hooks",
        description: "Actions triggered during Copilot agent session lifecycle.",
        path: "hooks/",
        accentClass: "card-category-automation",
        countKey: "hooks",
      },
      {
        id: "workflows",
        icon: "workflow" as const,
        title: "Workflows",
        description: "Markdown-defined automations that run as GitHub Actions.",
        path: "workflows/",
        accentClass: "card-category-automation",
        countKey: "workflows",
      },
    ],
  },
  {
    title: "Extend and learn",
    description: "Explore the ecosystem, tooling, and guided tutorials.",
    items: [
      {
        id: "tools",
        icon: "wrench" as const,
        title: "Tools",
        description: "MCP servers, editor integrations, and developer tooling.",
        path: "tools/",
        accentClass: "card-category-dev",
        countKey: "tools",
      },
      {
        id: "extensions",
        icon: "plug" as const,
        title: "Canvas Extensions",
        description: "Interactive canvas add-ons for Copilot app experiences.",
        path: "extensions/",
        accentClass: "card-category-extension",
        countKey: "extensions",
      },
      {
        id: "learning-hub",
        icon: "book" as const,
        title: "Learning Hub",
        description: "Guides and tutorials covering agents, skills, MCP servers, and agentic workflows.",
        path: "learning-hub/",
        accentClass: "card-category-learn",
      },
    ],
  },
];

const stats = [
  { label: "Resources", key: "total" },
  { label: "Agents", key: "agents" },
  { label: "Skills", key: "skills" },
  { label: "Instructions", key: "instructions" },
  { label: "Plugins", key: "plugins" },
];
---

<StarlightPage
  frontmatter={{
    title: "Awesome GitHub Copilot",
    description:
      "Community-contributed agents, instructions, and skills to enhance your GitHub Copilot experience",
    template: "splash",
    pagefind: false,
    prev: false,
    next: false,
    editUrl: false,
    head: [
      {
        tag: "meta",
        attrs: {
          property: "og:type",
          content: "website",
        },
      },
    ],
  }}
  hasSidebar={false}
>
  <div id="main-content">
    <Hero stats={stats} />
    <QuickLinks title="Browse Resources" categories={categories} />
    <HowItWorks />
    <InstallCard />
    <CommunityCTA />
  </div>

  <Modal />

  <!-- Back to Top Button -->
  <BackToTop />

  <script>
    import "../scripts/pages/index";
  </script>
</StarlightPage>
