---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Card from '../components/ui/Card.astro';
import Icon from '../components/ui/Icon.astro';
import ContributeCTA from '../components/ContributeCTA.astro';
import BackToTop from '../components/BackToTop.astro';
import hooksData from '../../public/data/hooks.json';

const rawItems = hooksData.items;
const uniqueHooks = new Set(rawItems.flatMap((item) => item.hooks)).size;
const assetEnabledCount = rawItems.filter((item) => item.assets.length > 0).length;
const tags = [...new Set(rawItems.flatMap((item) => item.tags))].sort();
---

<BaseLayout title="Hooks · Awesome GitHub Copilot" description="Automated workflows triggered by Copilot coding agent events">
  <section id="hooks" class="section" aria-labelledby="hooks-title">
    <Container>
      <Card class="console-header-card">
        <div class="console-summary-text">
          <p class="console-eyebrow">/hooks · fuzzy search + on-demand details</p>
          <h1 id="hooks-title" class="console-title">Hooks automation console</h1>
          <p class="console-description">Filter Copilot coding agent hooks by tag, then open a focused internal detail UI.</p>
        </div>

        <dl class="console-stats-grid" aria-label="Hook stats">
          <div class="console-stat-card console-stat-card--active"><dd>{rawItems.length}</dd><dt>hooks</dt></div>
          <div class="console-stat-card"><dd>{uniqueHooks}</dd><dt>events</dt></div>
          <div class="console-stat-card"><dd>{assetEnabledCount}</dd><dt>with assets</dt></div>
        </dl>
      </Card>

      <div class="console-filter-bar" id="filters-bar">
        <label class="console-search-control">
          <span aria-hidden="true" class="console-prompt">&gt;</span>
          <span class="sr-only">Search hooks</span>
          <input id="hook-search" type="search" placeholder="search hooks…" aria-label="Search hooks" autocomplete="off" />
          <Icon name="search" size={16} />
        </label>

        <label class="console-select-control console-select-control--wide console-select-control--active" for="filter-tag">
          <span class="console-control-copy"><span aria-hidden="true" class="console-prompt">&gt;</span> <span class="filter-display" data-param="tag">tag: all</span></span>
          <Icon name="keyboard-arrow-down" size={16} />
          <select id="filter-tag" data-filter-param="tag" multiple aria-label="Filter hooks by tag">
            {tags.map((tag) => <option value={tag}>{tag}</option>)}
          </select>
        </label>

        <label class="console-select-control console-select-control--wide console-select-control--active" for="filter-hook">
          <span class="console-control-copy"><span aria-hidden="true" class="console-prompt">&gt;</span> <span class="filter-display" data-param="hook">hook: all</span></span>
          <Icon name="keyboard-arrow-down" size={16} />
          <select id="filter-hook" data-filter-param="hook" aria-label="Filter hooks by event">
            <option value="">All Events</option>
          </select>
        </label>

        <label class="console-select-control console-select-control--sort" for="sort-select">
          <span class="console-control-copy"><span aria-hidden="true" class="console-prompt console-prompt--muted">&gt;</span> <span class="filter-display" data-param="sort">sort: all</span></span>
          <Icon name="keyboard-arrow-down" size={16} />
          <select id="sort-select" data-filter-param="sort" data-default-value="title" aria-label="Sort hooks">
            <option value="title">Name (A-Z)</option>
            <option value="lastUpdated">Recently Updated</option>
          </select>
        </label>

        <button class="console-reset-control" type="button" aria-label="Clear filters" id="filter-clear"><Icon name="delete" size={15} /></button>
      </div>

      <section class="marketplace-results" aria-label="Matching hooks"><div class="results-meta"><p id="resource-count">Loading hooks...</p></div></section>
      <div id="hook-grid" class="resource-grid" role="list"></div>
      <div id="hook-load-sentinel" class="agent-load-sentinel" aria-hidden="true"></div>
      <button id="hook-load-more" class="filter-clear agent-load-more" type="button" hidden>Load more hooks</button>

      <div id="empty-state" class="empty-state" hidden><h3>No hooks found</h3><p>Try adjusting your search or filters.</p><button id="empty-clear" class="filter-clear" type="button">Clear all filters</button></div>
      <div id="hook-search-results" class="search-results-dropdown" role="listbox" aria-label="Search results"></div>
      <div id="hook-search-status" class="search-status" role="status" aria-live="polite" aria-atomic="true"></div>

      <ContributeCTA resourceType="hooks" />
    </Container>
  </section>

  <BackToTop />
</BaseLayout>

<script>
  import { initResourceCatalog, stableAccent, type CatalogClientItem } from '../scripts/resource-catalog';
  import type { HookItem } from '../lib/upstream-types';

  function toClientItem(item: HookItem): CatalogClientItem {
    return {
      id: item.id,
      title: item.title,
      label: item.hooks.length === 1 ? item.hooks[0] : `${item.hooks.length} events`,
      description: item.description,
      tags: [...item.tags.slice(0, 4), ...item.hooks.slice(0, 2)],
      accent: stableAccent(item.id),
      href: `/hook/${encodeURIComponent(item.id)}/`,
      detail: item.readmeFile ?? item.path,
      sortDate: item.lastUpdated,
      filters: { tag: item.tags, hook: item.hooks },
      searchText: `${item.title} ${item.description} ${item.tags.join(' ')} ${item.hooks.join(' ')}`,
    };
  }

  (async () => {
    // Populate hook event filter options
    const hookSelect = document.getElementById('filter-hook') as HTMLSelectElement | null;
    if (hookSelect) {
      try {
        const response = await fetch('/data/hooks.json');
        const data = await response.json();
        const hooks = [...new Set(data.items.flatMap((item: any) => item.hooks))].sort();
        hookSelect.innerHTML = '<option value="">All Events</option>' +
          // Cast to string[] — flatMap on untyped JSON data produces unknown[].
          (hooks as string[]).map((h) => `<option value="${h}">${h}</option>`).join('');
      } catch (e) {
        console.error('Failed to load hook events:', e);
      }
    }

    // Initialize custom dropdowns for single-select controls
    const { initCustomDropdowns } = await import('../scripts/custom-dropdown');
    initCustomDropdowns();

    initResourceCatalog<HookItem>({
      dataUrl: 'data/hooks.json', gridSelector: '#hook-grid', countSelector: '#resource-count', emptySelector: '#empty-state',
      searchInputSelector: '#hook-search', searchResultsSelector: '#hook-search-results', searchStatusSelector: '#hook-search-status',
      loadMoreSelector: '#hook-load-more', loadSentinelSelector: '#hook-load-sentinel', clearSelector: '#filter-clear', emptyClearSelector: '#empty-clear',
      resourceName: 'hook', resourceNamePlural: 'hooks', defaultSort: 'title',
      filterConfigs: [{ param: 'tag', label: 'Tag', type: 'multi' }, { param: 'hook', label: 'Hook', type: 'single' }, { param: 'sort', label: 'Sort', type: 'single', defaultValue: 'title' }],
      toClientItem,
    });
  })();
</script>
