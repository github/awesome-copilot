---
import fs from 'node:fs';
import path from 'node:path';
import { marked } from 'marked';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResourceDetailPage from '../../components/ResourceDetailPage.astro';
import pluginsData from '../../../public/data/plugins.json';
import type { PluginItem, PluginsData } from '../../lib/upstream-types';
import { parseFrontmatter } from '../../lib/frontmatter';

export function getStaticPaths() {
  return (pluginsData as PluginsData).items.map((item: PluginItem) => ({
    params: { id: item.id },
  }));
}

const { id } = Astro.params;
const item = (pluginsData as PluginsData).items.find((i: PluginItem) => i.id === id);
const repoRoot = path.resolve(process.cwd(), '..');
  let markdownHtml = '';
  let frontmatterText: string | null = null;
  if (item) {
    const mdPath = path.resolve(repoRoot, item.path, 'README.md');
    try {
      const md = fs.readFileSync(mdPath, 'utf-8');
      const parsed = parseFrontmatter(md);
      frontmatterText = parsed.frontmatter;
      markdownHtml = marked.parse(parsed.body) as string;
    } catch {
      markdownHtml = '';
    }
  }
---

<BaseLayout title="Plugin · Awesome Copilot" description="Explore and install a GitHub Copilot plugin.">
  <ResourceDetailPage kind="plugin" plural="plugins" title="Plugins" description="Fetching plugin details on demand." markdownHtml={markdownHtml} frontmatter={frontmatterText} />
</BaseLayout>

<script>
  import { initCopyButtons, initResourceDetail } from '../../scripts/resource-detail';

  initCopyButtons();
  initResourceDetail('plugin');
</script>
