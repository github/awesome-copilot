---
import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import { marked } from 'marked';
import matter from 'gray-matter';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import BackToTop from '../../components/BackToTop.astro';
import agentsData from '../../../public/data/agents.json';

interface AgentItem {
  id: string;
  title: string;
  description?: string;
  model?: string | string[];
  tools?: string[];
  hasHandoffs?: boolean;
  handoffs?: string[];
  mcpServers?: string[];
  path: string;
  filename?: string;
  lastUpdated?: string | null;
}

export function getStaticPaths() {
  return (agentsData.items as AgentItem[]).map((item) => ({
    params: { id: item.id },
    props: { item },
  }));
}

const { item } = Astro.props as { item: AgentItem };

// --- Install / source URL helpers (kept in sync with src/scripts/utils.ts) ---
const RAW_BASE = 'https://raw.githubusercontent.com/github/awesome-copilot/main';
const GITHUB_BASE = 'https://github.com/github/awesome-copilot/blob/main';

function vscodeInstallUrl(filePath: string, insiders = false): string {
  const rawUrl = `${RAW_BASE}/${filePath}`;
  const scheme = insiders ? 'vscode-insiders' : 'vscode';
  const innerUrl = `${scheme}:chat-agent/install?url=${encodeURIComponent(rawUrl)}`;
  return `https://aka.ms/awesome-copilot/install/agent?url=${encodeURIComponent(innerUrl)}`;
}

const vscodeUrl = vscodeInstallUrl(item.path, false);
const insidersUrl = vscodeInstallUrl(item.path, true);
const githubUrl = `${GITHUB_BASE}/${item.path}`;

// --- Read + render the agent markdown at build time ---
const repoRoot = fileURLToPath(new URL('../../../../', import.meta.url));
let markdownHtml = '';
let frontmatterText = '';
let rawMarkdown = '';
try {
  const raw = fs.readFileSync(path.join(repoRoot, item.path), 'utf-8');
  rawMarkdown = raw;
  const parsed = matter(raw);
  frontmatterText = parsed.matter?.trim() ?? '';
  markdownHtml = marked.parse(parsed.content, { async: false }) as string;
} catch {
  markdownHtml = '';
}

const models = Array.isArray(item.model)
  ? item.model
  : item.model
    ? [item.model]
    : [];
const tools = item.tools ?? [];
const handoffs = item.handoffs ?? [];
const mcpServers = item.mcpServers ?? [];

const lastUpdated = item.lastUpdated
  ? new Date(item.lastUpdated).toLocaleDateString(undefined, {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<StarlightPage frontmatter={{ title: item.title, description: item.description, template: 'splash', prev: false, next: false, editUrl: false }}>
  <div id="main-content" class="agent-detail-page" data-agent-detail data-path={item.path}>
    {rawMarkdown && <textarea data-raw-markdown hidden aria-hidden="true" readonly>{rawMarkdown}</textarea>}
    <div class="container">
      <nav class="detail-breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/agents/">Agents</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{item.title}</span>
      </nav>

      <header class="detail-header">
        <h1>{item.title}</h1>
        {item.description && <p class="detail-description">{item.description}</p>}
      </header>

      <div class="detail-layout">
        <main class="detail-main">
          {markdownHtml ? (
            <section class="detail-section" aria-labelledby="doc-heading">
              <h2 id="doc-heading">Documentation</h2>
              <div class="article-content" set:html={markdownHtml} />
            </section>
          ) : (
            <section class="detail-section">
              <p class="detail-empty">Documentation preview is unavailable. View the file <a href={githubUrl} target="_blank" rel="noopener">on GitHub</a>.</p>
            </section>
          )}
        </main>

        <aside class="detail-sidebar" aria-label="Agent details">
          <section class="detail-card detail-actions-card" data-actions>
            <div class="install-dropdown" data-install-menu>
              <a class="btn btn-primary install-btn-main" href={vscodeUrl} target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                Install
              </a>
              <button type="button" class="btn btn-primary install-btn-toggle" aria-label="More install options" aria-haspopup="true" aria-expanded="false" data-install-toggle>
                <svg viewBox="0 0 16 16" width="12" height="12" fill="currentColor" aria-hidden="true"><path d="M4.427 7.427l3.396 3.396a.25.25 0 00.354 0l3.396-3.396A.25.25 0 0011.396 7H4.604a.25.25 0 00-.177.427z"/></svg>
              </button>
              <div class="install-dropdown-menu" role="menu">
                <a href={vscodeUrl} target="_blank" rel="noopener" role="menuitem">Install in VS Code</a>
                <a href={insidersUrl} target="_blank" rel="noopener" role="menuitem">Install in VS Code Insiders</a>
                <div class="dropdown-divider"></div>
                <a href="#" role="menuitem" data-action="download">Download file</a>
                {rawMarkdown && <a href="#" role="menuitem" data-action="copy-markdown">Copy markdown</a>}
              </div>
            </div>
            <div class="detail-actions-secondary">
              <button class="btn btn-secondary" type="button" data-action="share">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="M8.59 13.51l6.83 3.98M15.41 6.51l-6.82 3.98"/></svg>
                Share
              </button>
              <a class="btn btn-secondary" href={githubUrl} target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.5.5.09.68-.22.68-.48 0-.24-.01-.87-.01-1.71-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02.8-.22 1.65-.33 2.5-.33.85 0 1.7.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85 0 1.34-.01 2.42-.01 2.75 0 .27.18.58.69.48A10.01 10.01 0 0022 12c0-5.52-4.48-10-10-10z"/></svg>
                View on GitHub
              </a>
            </div>
          </section>

          <section class="detail-card">
            <h2>Details</h2>
            <dl class="detail-meta">
              <div>
                <dt>Model</dt>
                <dd>
                  {models.length ? (
                    <div class="detail-chips">
                      {models.map((m) => <span class="resource-tag tag-model">{m}</span>)}
                    </div>
                  ) : <span class="detail-none">Not specified</span>}
                </dd>
              </div>
              <div>
                <dt>Handoffs</dt>
                <dd>
                  {handoffs.length ? (
                    <div class="detail-chips">
                      {handoffs.map((h) => <span class="resource-tag tag-handoffs">{h}</span>)}
                    </div>
                  ) : item.hasHandoffs ? <span class="resource-tag tag-handoffs">enabled</span> : <span class="detail-none">None</span>}
                </dd>
              </div>
              {mcpServers.length > 0 && (
                <div>
                  <dt>MCP servers</dt>
                  <dd>
                    <div class="detail-chips">
                      {mcpServers.map((s) => <span class="resource-tag">{s}</span>)}
                    </div>
                  </dd>
                </div>
              )}
              <div>
                <dt>Tools ({tools.length})</dt>
                <dd>
                  {tools.length ? (
                    <div class="detail-chips">
                      {tools.map((t) => <span class="resource-tag">{t}</span>)}
                    </div>
                  ) : <span class="detail-none">None</span>}
                </dd>
              </div>
              <div>
                <dt>Source</dt>
                <dd><code class="detail-path">{item.path}</code></dd>
              </div>
              {lastUpdated && (
                <div>
                  <dt>Last updated</dt>
                  <dd>{lastUpdated}</dd>
                </div>
              )}
            </dl>
          </section>

          {frontmatterText && (
            <section class="detail-card">
              <details class="detail-frontmatter">
                <summary>Frontmatter</summary>
                <pre><code>{frontmatterText}</code></pre>
              </details>
            </section>
          )}
        </aside>
      </div>
    </div>
  </div>

  <BackToTop />

  <script>
    import '../../scripts/pages/agent-detail';
  </script>
</StarlightPage>

<style>
  .agent-detail-page {
    padding-block: 2rem 3rem;
  }
  .detail-breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }
  .detail-breadcrumbs a {
    color: var(--color-link);
    text-decoration: none;
  }
  .detail-breadcrumbs a:hover {
    color: var(--color-link-hover);
    text-decoration: underline;
  }
  .detail-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .detail-header h1 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: var(--color-text-emphasis);
  }
  .detail-description {
    margin: 0;
    max-width: 60ch;
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }
  .detail-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 22rem);
    gap: 2rem;
    align-items: start;
  }
  .detail-sidebar {
    position: sticky;
    top: 1.5rem;
    display: grid;
    gap: 1rem;
  }
  .detail-card {
    padding: 1.25rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }
  .detail-card h2 {
    margin: 0 0 1rem;
    font-size: 1.1rem;
    color: var(--color-text-emphasis);
  }
  .detail-actions-card {
    display: grid;
    gap: 0.75rem;
  }
  .detail-actions-card .install-dropdown {
    display: flex;
    width: 100%;
  }
  .detail-actions-card .install-btn-main {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
  }
  .detail-actions-card .install-dropdown-menu {
    left: 0;
    right: 0;
    min-width: 0;
    z-index: 10;
  }
  .detail-actions-secondary {
    display: grid;
    gap: 0.5rem;
  }
  .detail-actions-secondary .btn {
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
  }
  .detail-section {
    min-width: 0;
  }
  .detail-section h2 {
    margin: 0 0 1rem;
    font-size: 1.35rem;
    color: var(--color-text-emphasis);
  }
  .detail-meta {
    margin: 0;
    display: grid;
    gap: 1rem;
  }
  .detail-meta > div {
    display: grid;
    gap: 0.4rem;
  }
  .detail-meta dt {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
  }
  .detail-meta dd {
    margin: 0;
    color: var(--color-text);
    font-size: 0.9rem;
  }
  .detail-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .detail-none {
    color: var(--color-text-muted);
    font-style: italic;
  }
  .detail-path {
    font-size: 0.82rem;
    word-break: break-all;
  }
  .detail-frontmatter summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--color-text-emphasis);
  }
  .detail-frontmatter pre {
    margin-top: 0.75rem;
    padding: 0.75rem;
    overflow-x: auto;
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 0.8rem;
  }
  .detail-empty {
    color: var(--color-text-muted);
  }

  @media (max-width: 900px) {
    .detail-layout {
      grid-template-columns: 1fr;
    }
    .detail-sidebar {
      position: static;
    }
  }
</style>
