---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResourceDetailPage from '../../components/ResourceDetailPage.astro';
import toolsData from '../../../public/data/tools.json';
import type { ToolItem, ToolsData } from '../../lib/upstream-types';
import { SITE } from '../../config/site';

export function getStaticPaths() {
  return (toolsData as ToolsData).items.map((item: ToolItem) => ({
    params: { id: item.id },
  }));
}

const { id } = Astro.params;
const item = (toolsData as ToolsData).items.find((entry: ToolItem) => entry.id === id);
const canonicalUrl = item ? new URL(`/tool/${item.id}/`, SITE.url).toString() : undefined;
---

<BaseLayout
  title={item ? `${item.name} · Tool · Awesome Copilot` : 'Tool · Awesome Copilot'}
  description={item?.description ?? 'Explore and configure a GitHub Copilot tool.'}
  canonicalUrl={canonicalUrl}
  socialTitle={item ? `${item.name} · Tool` : 'Tool · Awesome Copilot'}
  socialDescription={item?.description ?? 'Explore and configure a GitHub Copilot tool.'}
>
  <ResourceDetailPage kind="tool" plural="tools" title="Tools" description="Fetching tool details on demand." />
</BaseLayout>

<script>
  import { initCopyButtons, initResourceDetail } from '../../scripts/resource-detail';

  initCopyButtons();
  initResourceDetail('tool');
</script>
