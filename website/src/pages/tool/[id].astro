---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResourceDetailPage from '../../components/ResourceDetailPage.astro';
import toolsData from '../../../public/data/tools.json';
import type { ToolItem, ToolsData } from '../../lib/upstream-types';

export function getStaticPaths() {
  return (toolsData as ToolsData).items.map((item: ToolItem) => ({
    params: { id: item.id },
  }));
}
---

<BaseLayout title="Tool · Awesome Copilot" description="Explore and configure a GitHub Copilot tool.">
  <ResourceDetailPage kind="tool" plural="tools" title="Tools" description="Fetching tool details on demand." />
</BaseLayout>

<script>
  import { initCopyButtons, initResourceDetail } from '../../scripts/resource-detail';

  initCopyButtons();
  initResourceDetail('tool');
</script>
