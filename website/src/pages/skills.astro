---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Card from '../components/ui/Card.astro';
import Icon from '../components/ui/Icon.astro';
import ContributeCTA from '../components/ContributeCTA.astro';
import BackToTop from '../components/BackToTop.astro';
import skillsData from '../../public/data/skills.json';

const rawItems = skillsData.items;
const assetEnabledCount = rawItems.filter((item) => item.hasAssets).length;
const bundledFileCount = rawItems.reduce((total, item) => total + item.files.length, 0);
---

<BaseLayout title="Skills · Awesome GitHub Copilot" description="Self-contained agent skills with instructions and bundled resources">
  <section id="skills" class="section" aria-labelledby="skills-title">
    <Container>
      <Card class="console-header-card">
        <div class="console-summary-text">
          <p class="console-eyebrow">/skills · fuzzy search + on-demand details</p>
          <h1 id="skills-title" class="console-title">Skills marketplace console</h1>
          <p class="console-description">Browse self-contained agent skills without mounting the full catalog up front.</p>
        </div>

        <dl class="console-stats-grid" aria-label="Skill stats">
          <div class="console-stat-card console-stat-card--active"><dd>{rawItems.length}</dd><dt>skills</dt></div>
          <div class="console-stat-card"><dd>{assetEnabledCount}</dd><dt>with assets</dt></div>
          <div class="console-stat-card"><dd>{bundledFileCount}</dd><dt>bundled files</dt></div>
        </dl>
      </Card>

      <div class="console-filter-bar" id="filters-bar">
        <label class="console-search-control">
          <span aria-hidden="true" class="console-prompt">&gt;</span>
          <span class="sr-only">Search skills</span>
          <input id="skill-search" type="search" placeholder="search skills…" aria-label="Search skills" autocomplete="off" />
          <Icon name="search" size={16} />
        </label>

        <button class="console-toggle" type="button" data-filter-param="hasAssets" aria-pressed="false" aria-label="Toggle skills with assets only filter">
          <Icon name="filter-alt" size={15} />
          <span>with assets</span>
        </button>

        <label class="console-select-control console-select-control--sort" for="sort-select">
          <span class="console-control-copy"><span aria-hidden="true" class="console-prompt console-prompt--muted">&gt;</span> <span class="filter-display" data-param="sort">sort: all</span></span>
          <select id="sort-select" data-filter-param="sort" data-default-value="title" aria-label="Sort skills">
            <option value="title">Name (A-Z)</option>
            <option value="lastUpdated">Recently Updated</option>
          </select>
        </label>

        <button class="console-reset-control" type="button" aria-label="Clear filters" id="filter-clear"><Icon name="delete" size={15} /></button>
      </div>

      <section class="marketplace-results" aria-label="Matching skills">
        <div class="results-meta"><p id="resource-count">Loading skills...</p></div>
      </section>

      <div id="skill-grid" class="resource-grid" role="list"></div>
      <div id="skill-load-sentinel" class="agent-load-sentinel" aria-hidden="true"></div>
      <button id="skill-load-more" class="filter-clear agent-load-more" type="button" hidden>Load more skills</button>

      <div id="empty-state" class="empty-state" hidden>
        <h3>No skills found</h3>
        <p>Try adjusting your search or filters.</p>
        <button id="empty-clear" class="filter-clear" type="button">Clear all filters</button>
      </div>

      <div id="skill-search-results" class="search-results-dropdown" role="listbox" aria-label="Search results"></div>
      <div id="skill-search-status" class="search-status" role="status" aria-live="polite" aria-atomic="true"></div>

      <ContributeCTA resourceType="skills" />
    </Container>
  </section>

  <BackToTop />
</BaseLayout>

<script>
  import { initResourceCatalog, stableAccent, type CatalogClientItem } from '../scripts/resource-catalog';
  import type { SkillItem } from '../lib/upstream-types';

  function toClientItem(item: SkillItem): CatalogClientItem {
    const label = item.hasAssets ? `${item.assetCount} assets` : 'skill';
    return {
      id: item.id,
      title: item.title,
      label,
      description: item.description || 'No description',
      tags: [item.category, item.hasAssets ? 'assets' : 'single file', `${item.files.length} files`].filter(Boolean),
      accent: stableAccent(item.id),
      href: `/skill/${encodeURIComponent(item.id)}/`,
      detail: item.skillFile,
      sortDate: item.lastUpdated,
      filters: {
        hasAssets: item.hasAssets ? ['1'] : [],
      },
      searchText: `${item.title} ${item.description} ${item.category} ${item.assets.join(' ')}`,
    };
  }

  (async () => {
    // Initialize custom dropdowns for single-select controls
    const { initCustomDropdowns } = await import('../scripts/custom-dropdown');
    initCustomDropdowns();

    initResourceCatalog<SkillItem>({
      dataUrl: 'data/skills.json',
      gridSelector: '#skill-grid',
      countSelector: '#resource-count',
      emptySelector: '#empty-state',
      searchInputSelector: '#skill-search',
      searchResultsSelector: '#skill-search-results',
      searchStatusSelector: '#skill-search-status',
      loadMoreSelector: '#skill-load-more',
      loadSentinelSelector: '#skill-load-sentinel',
      clearSelector: '#filter-clear',
      emptyClearSelector: '#empty-clear',
      resourceName: 'skill',
      resourceNamePlural: 'skills',
      defaultSort: 'title',
      filterConfigs: [
        { param: 'hasAssets', label: 'Has Assets', type: 'flag' },
        { param: 'sort', label: 'Sort', type: 'single', defaultValue: 'title' },
      ],
      toClientItem,
    });
  })();
</script>
