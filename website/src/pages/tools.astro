---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Card from '../components/ui/Card.astro';
import Icon from '../components/ui/Icon.astro';
import ContributeCTA from '../components/ContributeCTA.astro';
import BackToTop from '../components/BackToTop.astro';
import toolsData from '../../public/data/tools.json';

const rawItems = toolsData.items;
const featuredCount = rawItems.filter((item) => item.featured).length;
const categories = toolsData.filters.categories;
---

<BaseLayout title="Tools · Awesome GitHub Copilot" description="MCP servers and developer tools for GitHub Copilot">
  <section id="tools" class="section" aria-labelledby="tools-title">
    <Container>
      <Card class="console-header-card">
        <div class="console-summary-text">
          <p class="console-eyebrow">/tools · fuzzy search + on-demand details</p>
          <h1 id="tools-title" class="console-title">Tools marketplace console</h1>
          <p class="console-description">Filter Copilot-ready tools by category, then inspect capabilities and configuration in a dedicated internal detail UI.</p>
        </div>

        <dl class="console-stats-grid" aria-label="Tool stats">
          <div class="console-stat-card console-stat-card--active"><dd>{rawItems.length}</dd><dt>tools</dt></div>
          <div class="console-stat-card"><dd>{featuredCount}</dd><dt>featured</dt></div>
          <div class="console-stat-card"><dd>{categories.length}</dd><dt>categories</dt></div>
        </dl>
      </Card>

      <div class="console-filter-bar" id="filters-bar">
        <label class="console-search-control">
          <span aria-hidden="true" class="console-prompt">&gt;</span>
          <span class="sr-only">Search tools</span>
          <input id="tool-search" type="search" placeholder="search tools…" aria-label="Search tools" autocomplete="off" />
          <Icon name="search" size={16} />
        </label>

        <label class="console-select-control console-select-control--wide console-select-control--active" for="filter-category">
          <span class="console-control-copy"><span aria-hidden="true" class="console-prompt">&gt;</span> <span class="filter-display" data-param="category">category: all</span></span>
          <Icon name="keyboard-arrow-down" size={16} />
          <select id="filter-category" data-filter-param="category" aria-label="Filter tools by category">
            <option value="">All Categories</option>
            {categories.map((category) => <option value={category}>{category}</option>)}
          </select>
        </label>

        <label class="console-select-control console-select-control--sort" for="sort-select">
          <span class="console-control-copy"><span aria-hidden="true" class="console-prompt console-prompt--muted">&gt;</span> <span class="filter-display" data-param="sort">sort: Featured First</span></span>
          <Icon name="keyboard-arrow-down" size={16} />
          <select id="sort-select" data-filter-param="sort" data-default-value="featured" aria-label="Sort tools">
            <option value="featured">Featured First</option>
            <option value="title">Title</option>
          </select>
        </label>

        <button class="console-reset-control" type="button" aria-label="Clear filters" id="filter-clear"><Icon name="delete" size={15} /></button>
      </div>

      <section class="marketplace-results" aria-label="Matching tools">
        <div class="results-meta"><p id="resource-count">Loading tools...</p></div>
      </section>

      <div id="tool-grid" class="resource-grid" role="list"></div>
      <div id="tool-load-sentinel" class="agent-load-sentinel" aria-hidden="true"></div>
      <button id="tool-load-more" class="filter-clear agent-load-more" type="button" hidden>Load more tools</button>

      <div id="empty-state" class="empty-state" hidden>
        <h3>No tools found</h3>
        <p>Try adjusting your search or filters.</p>
        <button id="empty-clear" class="filter-clear" type="button">Clear all filters</button>
      </div>

      <div id="tool-search-results" class="search-results-dropdown" role="listbox" aria-label="Search results"></div>
      <div id="tool-search-status" class="search-status" role="status" aria-live="polite" aria-atomic="true"></div>

      <Card class="coming-soon-card">
        <h2>More Tools Coming Soon</h2>
        <p>We're working on additional tools to enhance your GitHub Copilot experience. Check back soon!</p>
      </Card>

      <ContributeCTA resourceType="tools" />
    </Container>
  </section>

  <BackToTop />
</BaseLayout>

<script>
  import { initResourceCatalog, stableAccent, type CatalogClientItem } from '../scripts/resource-catalog';
  import type { ToolItem } from '../lib/upstream-types';

  function toClientItem(item: ToolItem): CatalogClientItem {
    return {
      id: item.id,
      title: item.name,
      label: item.featured ? 'featured' : item.category,
      description: item.description,
      tags: [item.category, ...item.tags].slice(0, 5),
      accent: stableAccent(item.id),
      href: `/tool/${encodeURIComponent(item.id)}/`,
      detail: item.configuration?.type ?? item.category,
      sortTitle: item.name,
      filters: {
        category: [item.category],
        featured: item.featured ? ['true'] : [],
      },
      searchText: `${item.name} ${item.description} ${item.category} ${item.tags.join(' ')} ${item.features.join(' ')} ${item.requirements.join(' ')}`,
    };
  }

  (async () => {
    const { initCustomDropdowns } = await import('../scripts/custom-dropdown');
    initCustomDropdowns();

    initResourceCatalog<ToolItem>({
      dataUrl: 'data/tools.json',
      gridSelector: '#tool-grid',
      countSelector: '#resource-count',
      emptySelector: '#empty-state',
      searchInputSelector: '#tool-search',
      searchResultsSelector: '#tool-search-results',
      searchStatusSelector: '#tool-search-status',
      loadMoreSelector: '#tool-load-more',
      loadSentinelSelector: '#tool-load-sentinel',
      clearSelector: '#filter-clear',
      emptyClearSelector: '#empty-clear',
      resourceName: 'tool',
      resourceNamePlural: 'tools',
      defaultSort: 'featured',
      filterConfigs: [
        { param: 'category', label: 'Category', type: 'single' },
        { param: 'sort', label: 'Sort', type: 'single', defaultValue: 'featured' },
      ],
      toClientItem,
    });
  })();
</script>

<style>
  .coming-soon-card {
    margin-top: var(--space-6);
    text-align: center;
  }

  .coming-soon-card h2 {
    margin: 0 0 var(--space-2);
  }

  .coming-soon-card p {
    margin: 0;
    color: var(--color-muted);
  }
</style>
