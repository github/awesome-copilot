---

{
  label ? (
    <svg
      role="img"
      aria-label={label}
      class="icon"
      width={size}
      height={size}
      viewBox="0 0 24 24"
      fill="currentColor"
    >
      <path d={paths[name] ?? paths.bolt}></path>
    </svg>
  ) : (
    <svg
      aria-hidden="true"
      class="icon"
      width={size}
      height={size}
      viewBox="0 0 24 24"
      fill="currentColor"
    >
      <path d={paths[name] ?? paths.bolt}></path>
    </svg>
  )
}

<style>
  .icon {
    display: inline-block;
    flex: none;
    shape-rendering: crispEdges;
  }
</style>
