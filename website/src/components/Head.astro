---
import starlightOverrides from '../styles/starlight-overrides.css?raw';
import Default from '@astrojs/starlight/components/Head.astro';
const { head, entry } = Astro.locals.starlightRoute;
const basePath = import.meta.env.BASE_URL;

const getMetaContent = (key: string, attribute: 'name' | 'property' = 'name'): string | undefined => {
  const content = head.find((tag) => tag.tag === 'meta' && tag.attrs?.[attribute] === key)?.attrs?.content;
  return typeof content === 'string' ? content : undefined;
};

const getLinkHref = (rel: string): string | undefined => {
  const href = head.find((tag) => tag.tag === 'link' && tag.attrs?.rel === rel)?.attrs?.href;
  return typeof href === 'string' ? href : undefined;
};

const twitterTitle = entry.data.title;
const description =
  entry.data.description ??
  getMetaContent('description') ??
  getMetaContent('og:description', 'property');
const canonicalUrl =
  getLinkHref('canonical') ?? getMetaContent('og:url', 'property');
const socialImageUrl =
  getMetaContent('twitter:image') ?? getMetaContent('og:image', 'property');
const socialImageAlt =
  getMetaContent('twitter:image:alt') ??
  getMetaContent('og:image:alt', 'property') ??
  description;
const socialImageType = socialImageUrl?.endsWith('.png')
  ? 'image/png'
  : socialImageUrl?.endsWith('.jpg') || socialImageUrl?.endsWith('.jpeg')
    ? 'image/jpeg'
    : socialImageUrl?.endsWith('.webp')
      ? 'image/webp'
      : undefined;

const twitterDomain =
  canonicalUrl && URL.canParse(canonicalUrl)
    ? new URL(canonicalUrl).hostname
    : undefined;
---

<style is:inline set:html={starlightOverrides}></style>
<Default><slot /></Default>
{twitterTitle ? <meta name="twitter:title" content={twitterTitle} /> : null}
{description ? <meta name="twitter:description" content={description} /> : null}
{canonicalUrl ? <meta name="twitter:url" content={canonicalUrl} /> : null}
{twitterDomain ? <meta name="twitter:domain" content={twitterDomain} /> : null}
{socialImageUrl ? <meta property="og:image:secure_url" content={socialImageUrl} /> : null}
{socialImageType ? <meta property="og:image:type" content={socialImageType} /> : null}
{socialImageAlt ? <meta name="twitter:image:alt" content={socialImageAlt} /> : null}

<!-- Theme initialization script (runs early to prevent flash) -->
<script is:inline>
  (function() {
    const STORAGE_KEY = 'awesome-copilot-theme';
    const stored = localStorage.getItem(STORAGE_KEY);

    // Theme handling:
    // - 'dark' or 'light' → set data-theme attribute to that value
    // - 'auto' or unset → don't set data-theme (CSS media query handles system preference)
    if (stored === 'dark' || stored === 'light') {
      document.documentElement.setAttribute('data-theme', stored);
    }
    // For 'auto' or unset, no attribute means CSS media query controls theme
  })();
</script>

<script is:inline define:vars={{ basePath }}>
  // basePath setup for runtime use
  document.addEventListener('DOMContentLoaded', () => {
    if (document.body) {
      document.body.dataset.basePath = basePath;
    }
  });
</script>
{import.meta.env.PROD && (
  <>
    <meta
      name="ha-url"
      content="https://collector.githubapp.com/awesome-copilot-web/collect"
    />
    <script
      async
      defer
      src="https://analytics.githubassets.com/hydro-marketing.min.js"
    ></script>
  </>
)}
