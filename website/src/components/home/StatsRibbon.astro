---
export interface Stat {
  label: string;
  key: string;
}

export interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<p class="hero-stats" aria-label="Collection stats" id="stats-ribbon">
  {
    stats.map((stat, index) => (
      <span class="hero-stat">
        <span class="hero-stat-value" data-stat={stat.key} aria-label={`${stat.label} count`}>0</span>{" "}
        <span class="hero-stat-label">{stat.label}</span>
        {index < stats.length - 1 && <span class="hero-stat-separator" aria-hidden="true">·</span>}
      </span>
    ))
  }
</p>
