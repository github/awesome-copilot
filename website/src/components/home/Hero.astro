---
import Icon from '../Icon.astro';
import StatsRibbon from './StatsRibbon.astro';
import type { Stat } from './StatsRibbon.astro';

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
const base = import.meta.env.BASE_URL;
const githubUrl = 'https://github.com/github/awesome-copilot';
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="container">
    <p class="hero-eyebrow reveal">The Copilot customization community</p>
    <h1 id="hero-heading" class="hero-title reveal">
      <span class="hero-title--gradient">Supercharge</span> GitHub Copilot for the way you work
    </h1>
    <p class="hero-subtitle reveal">
      A community-curated library of agents, instructions, skills, and plugins.
      Search hundreds of resources, install in one command, or drop reusable
      guidance into your repo.
    </p>

    <div class="hero-search reveal" role="search" aria-label="Search resources">
      <div class="search-row">
        <input
          type="text"
          id="hero-search-input"
          placeholder="Search agents, skills, instructions..."
          aria-label="Search resources"
          autocomplete="off"
        />
        <span class="search-shortcut" aria-hidden="true">
          <kbd>/</kbd>
        </span>
      </div>
      <div
        id="hero-search-results"
        class="search-results hidden"
        aria-live="polite"
      >
      </div>
    </div>

    <div class="hero-actions reveal">
      <a href={`${base}agents/`} class="btn btn-primary">
        Browse all resources
        <Icon name="chevron-down" size={16} class="btn-icon-right" />
      </a>
      <a href={`${base}how-to-use/`} class="btn btn-secondary">
        How it works
      </a>
      <a
        href={githubUrl}
        class="btn btn-outline"
        target="_blank"
        rel="noopener"
      >
        Star on GitHub
      </a>
    </div>

    <p class="hero-micro reveal">
      No setup required — Awesome Copilot is already registered as a default marketplace.
    </p>

    <StatsRibbon stats={stats} />
  </div>
</section>
