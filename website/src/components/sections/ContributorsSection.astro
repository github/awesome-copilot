---
/**
 * Contributors section — renders contributors as 8bit CLI cards.
 * Reads `.all-contributorsrc` at build time and shows a preview of
 * contributors, linking to the full /contributors/ page.
 */
import fs from 'node:fs';
import path from 'node:path';
import BitButton from '../ui/8BitButton.astro';
import Container from '../ui/Container.astro';
import Icon from '../ui/Icon.astro';

interface AllContributor {
  login: string;
  name: string;
  avatar_url: string;
  profile: string;
  contributions: string[];
}

interface AllContributorsRc {
  projectName: string;
  contributors: AllContributor[];
}

const rcPath = path.resolve(process.cwd(), '../.all-contributorsrc');
const rc = JSON.parse(fs.readFileSync(rcPath, 'utf-8')) as AllContributorsRc;

const PREVIEW_COUNT = 24;
const contributors = rc.contributors.slice(0, PREVIEW_COUNT);
const total = rc.contributors.length;
---
<section class="contributors" aria-labelledby="contributors-title">
  <Container>
    <div class="contributors__head">
      <p class="contributors__kicker"><span class="contributors__dollar">$</span> git shortlog -sne | head -n {PREVIEW_COUNT}</p>
      <h2 id="contributors-title">Contributors</h2>
      <p class="contributors__sub">{total} humans shipping agents, skills, plugins, and instructions to the console.</p>
    </div>

    <ul class="contributors__grid" role="list">
      {contributors.map((c) => (
        <li class="contributor">
          <a class="contributor__link" href={c.profile || `https://github.com/${c.login}`} rel="noopener noreferrer" target="_blank">
            <span class="contributor__avatar" aria-hidden="true">
              <img src={c.avatar_url} alt="" width="40" height="40" loading="lazy" decoding="async" />
            </span>
            <span class="contributor__meta">
              <span class="contributor__name">{c.name || c.login}</span>
              <span class="contributor__handle">@{c.login}</span>
              <span class="contributor__count">{c.contributions.length} contribs</span>
            </span>
          </a>
        </li>
      ))}
    </ul>

    <div class="contributors__foot">
      <BitButton href="/contributors/"><Icon name="arrow" size={15} /> View all {total}</BitButton>
    </div>
  </Container>
</section>
<style>
  .contributors {
    padding-block: clamp(2.5rem, 5vw, 4rem);
    border-top: 4px solid var(--color-subtle);
  }

  .contributors__head {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.75rem;
    text-align: center;
    align-items: center;
  }

  .contributors__kicker {
    margin: 0;
    color: var(--color-green);
    font-family: var(--font-mono);
    font-weight: 800;
    font-size: 0.78rem;
    letter-spacing: 0.03em;
  }
  .contributors__dollar { color: var(--color-primary); }

  h2 {
    margin: 0;
    font-family: var(--font-mono);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .contributors__sub {
    max-width: 560px;
    margin: 0;
    color: var(--color-muted);
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .contributors__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
  }

  .contributor {
    display: flex;
    height: 100%;
  }

  .contributor__link {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    width: 100%;
    height: 100%;
    padding: 0.9rem 1rem;
    border: 2px solid var(--color-subtle);
    border-radius: 0;
    background: var(--color-bg-elevated);
    color: inherit;
    text-decoration: none;
    transition: border-color var(--motion-fast), background var(--motion-fast);
  }

  .contributor__link:hover {
    background: rgb(255 255 255 / 4%);
  }

  .contributor__link:focus-visible {
    outline: 2px solid rgb(255 255 255 / 35%);
    outline-offset: 2px;
  }

  .contributor__avatar {
    flex: none;
    width: 52px;
    height: 52px;
    display: grid;
    place-items: center;
    overflow: hidden;
    background: var(--color-bg);
  }
  .contributor__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
  }

  .contributor__meta {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    min-width: 0;
  }

  .contributor__name {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .contributor__handle {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--color-muted);
  }

  .contributor__count {
    margin-top: 0.15rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .contributors__foot {
    display: flex;
    justify-content: center;
    margin-top: 1.75rem;
  }
</style>
