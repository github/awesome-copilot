---
/**
 * CTA section — "next step" call to action, aligned with the FAQ section pattern.
 */
import BitButton from '../ui/8BitButton.astro';
import Container from '../ui/Container.astro';
import Icon from '../ui/Icon.astro';
---
<section class="cta" aria-labelledby="cta-title">
  <Container>
    <div class="cta-panel">
      <div class="cta-copy">
        <p class="cta-kicker">$ next step</p>
        <h2 id="cta-title">Ship Copilot resources without losing the system model.</h2>
        <p class="cta-sub">Bundle agents, instructions, skills, and plugins that keep your architecture intact — then ship them as a portable console.</p>
      </div>
      <div class="cta-action">
        <BitButton href="/"><Icon name="arrow" size={15} /> Explore console</BitButton>
      </div>
    </div>
  </Container>
</section>
<style>
  .cta {
    padding-block: 4rem 5rem;
    border-top: 1px solid var(--color-border-soft);
  }

  .cta-panel {
    max-width: 1080px;
    margin-inline: auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 3rem);
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border-top: 4px solid var(--color-subtle);
    border-bottom: 4px solid var(--color-subtle);
    border-left: 1px solid rgb(255 255 255 / 10%);
    border-right: 1px solid rgb(255 255 255 / 10%);
    background: var(--color-bg-elevated);
    box-shadow: 6px 6px 0 rgb(0 0 0 / 45%);
  }

  .cta-copy {
    display: grid;
    gap: 0.75rem;
  }

  .cta-kicker {
    margin: 0;
    color: var(--color-green);
    font-size: 0.88rem;
    font-weight: 800;
  }

  h2 {
    margin: 0;
    color: var(--color-text);
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.045em;
    line-height: 1.06;
  }

  .cta-sub {
    margin: 0;
    color: var(--color-muted);
    font-size: clamp(0.9rem, 1.5vw, 1rem);
    line-height: 1.55;
  }

  .cta-action {
    display: flex;
    justify-content: flex-end;
  }

  @media (max-width: 760px) {
    .cta-panel {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .cta-action {
      justify-content: flex-start;
    }
  }
</style>
