---
/**
 * Homepage hero section — ported from awesome-copilot-jh base UI.
 *
 * Preserves exact visual motifs: terminal label, headline, pixel mascot,
 * terminal search preview panel, retro resource cards.
 *
 * Resource cards and search preview are wired to upstream manifest/search data.
 */
import Container from '../ui/Container.astro';
import Icon from '../ui/Icon.astro';
import RetroResourceCard from '../ui/RetroResourceCard.astro';
import type { SearchResultEntry } from '../../lib/adapters/search';
import type { ResourceCard, Accent } from '../../lib/types';

interface Props {
  resources: ResourceCard[];
  searchEntries: SearchResultEntry[];
}

const { resources, searchEntries } = Astro.props;

/** Pick one representative per resource type for the hero preview so icons differ. */
function pickHeroPreview(entries: SearchResultEntry[]): SearchResultEntry[] {
  const types = ['agent', 'skill', 'hook'];
  return types
    .map((t) => entries.find((e) => e.type === t))
    .filter((e): e is SearchResultEntry => e !== undefined);
}

/** Icon name per section — maps manifest icon keys to Icon component names. */
const SECTION_ICON_MAP: Record<string, string> = {
  agent: 'agents',
  instruction: 'instructions',
  skill: 'skills',
  hook: 'hooks',
  workflow: 'workflows',
  plugin: 'plugins',
  tool: 'tools',
  user: 'robot',
  docs: 'docs',
};

/** Accent colour for search result rows. */
const RESULT_ACCENT: Accent[] = ['purple', 'blue', 'green'];
---

<section class="hero" aria-labelledby="hero-title">
  <Container>
    <div class="hero-console">
      <div class="hero-shell">
        <div class="hero-copy">
          <p class="terminal-label">$ pwd ~/awesome-copilot/search-index</p>
          <h1 id="hero-title">
            Build a sharper Copilot <span>setup.</span><i aria-hidden="true"></i>
          </h1>
          <p class="lead">Discover agents, skills, instructions, hooks, workflows, plugins and tools from one searchable retro-futuristic control panel.</p>

          <div class="command-search" role="search" aria-label="Global resource search preview">
            <span aria-hidden="true" class="prompt">&gt;</span>
            <span class="placeholder">Search agents, skills, instructions...</span>
          </div>

          <div class="quick-results" aria-label="Search result examples">
            {pickHeroPreview(searchEntries).map((entry, i) => (
              <a class:list={['quick-result', `quick-result--${RESULT_ACCENT[i] ?? 'purple'}`]} href={entry.route}>
                <Icon name={SECTION_ICON_MAP[entry.label.toLowerCase()] ?? 'terminal'} size={28} />
                <span>
                  <strong>&gt; {entry.title}</strong>
                  <small>{entry.description.length > 42 ? `${entry.description.slice(0, 42)}...` : entry.description}</small>
                </span>
              </a>
            ))}
          </div>
        </div>

        <div class="hero-visual" aria-hidden="true">
          <span class="pixel-star pixel-star--one">+</span>
          <span class="pixel-star pixel-star--two">+</span>
          <span class="pixel-star pixel-star--three">×</span>
          <img class="mascot" src="/copilot-icon.png" alt="" width="639" height="484" loading="eager" decoding="async" />
          <div class="status-console">
            <p><span></span> copilot@awesome:~$</p>
            <p>Ready to <strong>enhance your workflow.</strong><i></i></p>
          </div>
        </div>
      </div>

      <div class="resource-grid" aria-label="Resource categories">
        {resources.map((resource) => (
          <RetroResourceCard
            title={resource.title}
            label={resource.label}
            description={resource.description}
            href={resource.href}
            icon={SECTION_ICON_MAP[resource.icon] ?? resource.icon}
            accent={resource.accent}
          />
        ))}
      </div>
    </div>
  </Container>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border-soft);
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 78% 28%, rgb(169 112 255 / 2%), transparent 28rem),
      radial-gradient(circle at 66% 44%, rgb(45 140 255 / 2%), transparent 24rem);
  }

  .hero-console {
    position: relative;
    max-width: 1440px;
    margin-inline: auto;
    display: grid;
    gap: clamp(1.5rem, 3vw, 2.5rem);
    padding: clamp(2.8rem, 5vw, 4rem) clamp(1rem, 3vw, 2.5rem) 0;
  }

  .hero-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(20rem, 0.8fr);
    align-items: center;
    gap: clamp(2rem, 5vw, 5rem);
    min-height: clamp(30rem, 46vw, 38rem);
    border-bottom: 1px solid var(--color-border-soft);
    padding-bottom: clamp(0.5rem, 1.5vw, 1.5rem);
  }

  .hero-copy {
    display: grid;
    gap: 1rem;
    z-index: 1;
    min-width: 0;
    max-width: 58rem;
  }

  .terminal-label {
    width: fit-content;
    max-width: 100%;
    margin: 0;
    border: 2px solid rgb(255 192 87 / 55%);
    border-radius: 0;
    background: rgb(255 192 87 / 4%);
    color: var(--color-yellow);
    box-shadow: 3px 3px 0 rgb(0 0 0 / 80%);
    padding: 0.4rem 0.8rem;
    font-size: clamp(0.78rem, 1.4vw, 0.9rem);
    font-weight: 800;
    overflow-wrap: anywhere;
  }

  h1 {
    margin: 0;
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: clamp(2.6rem, 6.2vw, 5.2rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.05;
    text-wrap: balance;
    overflow-wrap: anywhere;
    text-shadow:
      0 3px 0 rgb(0 0 0 / 40%),
      3px 0 0 rgb(0 0 0 / 25%);
  }

  h1 span { color: var(--color-primary); }

  h1 i,
  .status-console i {
    display: inline-block;
    width: 0.26em;
    height: 0.54em;
    margin-left: 0.18em;
    background: var(--color-green);
    vertical-align: baseline;
  }

  .lead {
    max-width: 46rem;
    margin: 0;
    color: var(--color-muted);
    font-size: clamp(1rem, 1.65vw, 1.22rem);
    line-height: 1.55;
  }

  .command-search {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    width: min(100%, 45rem);
    min-width: 0;
    min-height: 3.5rem;
    margin-top: 0.75rem;
    border-top: 2px solid rgb(169 112 255 / 16%);
    border-bottom: 2px solid rgb(169 112 255 / 16%);
    border-left: 1px solid rgb(169 112 255 / 12%);
    border-right: 1px solid rgb(169 112 255 / 12%);
    background: rgb(5 7 7 / 78%);
    color: var(--color-muted);
    box-shadow: 0 0 18px rgb(0 0 0 / 55%);
    padding: 0.75rem 1rem;
  }

  .prompt {
    color: var(--color-green);
    font-weight: 900;
  }

  .placeholder {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .quick-results {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    width: min(100%, 49rem);
    margin-top: 0.65rem;
  }

  .quick-result {
    --quick-accent: var(--color-primary);
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
    border-right: 1px dashed var(--color-border);
    color: inherit;
    padding: 0.15rem 1rem 0.15rem 0;
    text-decoration: none;
  }

  .quick-result + .quick-result { padding-left: 1rem; }
  .quick-result:last-child { border-right: 0; }
  .quick-result--blue { --quick-accent: var(--color-blue); }
  .quick-result--green { --quick-accent: var(--color-green); }
  .quick-result :global(.icon) { color: var(--quick-accent); }

  .quick-result span {
    display: grid;
    gap: 0.2rem;
    min-width: 0;
  }

  .quick-result strong,
  .quick-result small {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .quick-result strong {
    color: var(--color-text);
    font-size: 0.88rem;
  }

  .quick-result small {
    color: var(--color-muted);
    font-size: 0.76rem;
  }

  .hero-visual {
    position: relative;
    display: grid;
    align-content: center;
    justify-items: center;
    align-self: stretch;
    min-height: 26rem;
    overflow: hidden;
    padding-left: 2.5rem;
  }

  .hero-visual::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgb(169 112 255 / 3%) 1px, transparent 1px),
      linear-gradient(90deg, rgb(169 112 255 / 3%) 1px, transparent 1px);
    background-size: 2rem 2rem;
    mask-image: radial-gradient(circle at center, #000 0 57%, transparent 78%);
    pointer-events: none;
  }

  .mascot {
    position: relative;
    z-index: 1;
    width: min(86%, 30rem);
    image-rendering: pixelated;
  }

  .pixel-star {
    position: absolute;
    color: var(--color-primary);
    font-weight: 900;
    opacity: 0.45;
  }

  .pixel-star--one { left: 14%; top: 20%; color: var(--color-blue); }
  .pixel-star--two { right: 18%; top: 68%; color: var(--color-primary); }
  .pixel-star--three { right: 10%; top: 32%; color: var(--color-blue); }

  .status-console {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.45rem;
    min-width: min(100%, 25rem);
    border: 1px solid rgb(255 255 255 / 10%);
    border-radius: 0;
    background: rgb(5 7 7 / 88%);
    padding: 1rem 1.25rem;
    margin-top: 1.5rem;
  }

  .status-console p {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0;
  }

  .status-console p:first-child { color: var(--color-green); }
  .status-console p:first-child span {
    width: 0.42rem;
    height: 0.42rem;
    background: var(--color-green);
  }

  .status-console strong {
    color: var(--color-primary);
    font-weight: 900;
  }

  .resource-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.25rem;
    width: 100%;
    max-width: 1440px;
    margin-inline: auto;
    padding-block: 2rem;
  }

  @media (max-width: 1100px) {
    .hero-shell { grid-template-columns: 1fr; }
    .hero-visual { min-height: 24rem; }
    .mascot { width: min(58%, 24rem); }
    .resource-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 760px) {
    .quick-results { grid-template-columns: 1fr; gap: 0.75rem; }
    .quick-result,
    .quick-result + .quick-result {
      border-right: 0;
      border-bottom: 1px dashed var(--color-border);
      padding: 0 0 0.75rem;
    }
    .quick-result:last-child { border-bottom: 0; }
    .hero-visual { min-height: 21rem; }
    .mascot { width: min(76%, 22rem); }
    .status-console {
      min-width: 0;
      width: calc(100% - 2rem);
    }
  }

  @media (max-width: 560px) {
    .hero-console { padding-inline: 1rem; }
    .hero-shell { min-height: auto; }
    .hero-visual { display: none; }
    .command-search {
      gap: 0.65rem;
      padding-inline: 0.85rem;
    }
    .placeholder {
      white-space: normal;
      overflow-wrap: anywhere;
      text-overflow: clip;
    }
    .resource-grid {
      grid-template-columns: 1fr;
      justify-items: center;
    }
    .resource-grid > * {
      width: min(100%, 30rem);
    }
  }
</style>
