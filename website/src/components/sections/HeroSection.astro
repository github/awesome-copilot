---
/**
 * Homepage hero section — ported from awesome-copilot-jh base UI.
 *
 * Preserves exact visual motifs: terminal label, headline, pixel mascot,
 * terminal search preview panel, retro resource cards.
 *
 * Resource cards and search preview are wired to upstream manifest/search data.
 */
import Badge from '../ui/Badge.astro';
import Container from '../ui/Container.astro';
import RetroResourceCard from '../ui/RetroResourceCard.astro';
import type { SearchResultEntry } from '../../lib/adapters/search';
import type { ResourceCard, Accent } from '../../lib/types';

interface Props {
  resources: ResourceCard[];
  searchEntries: SearchResultEntry[];
}

const { resources, searchEntries } = Astro.props;

/** Icon name per section — maps manifest icon keys to Icon component names. */
const SECTION_ICON_MAP: Record<string, string> = {
  agent: 'agents',
  instruction: 'instructions',
  skill: 'skills',
  hook: 'hooks',
  workflow: 'workflows',
  plugin: 'plugins',
  tool: 'tools',
  user: 'robot',
  docs: 'docs',
};

/** Accent colour for search result rows. */
const RESULT_ACCENT: Accent[] = ['purple', 'blue', 'green'];
---

<section class="hero" aria-labelledby="hero-title">
  <Container>
    <div class="hero-console">
      <div class="hero-copy">
        <p class="terminal-label">$ pwd ~/awesome-copilot/search-index</p>
        <h1 id="hero-title">Build a sharper Copilot setup.</h1>
        <p class="lead">Discover agents, skills, instructions, hooks, workflows, plugins and tools from one searchable retro-futuristic control panel.</p>
      </div>

      <img class="mascot" src="/copilot-icon.png" alt="Pixel-art GitHub Copilot robot mascot" width="639" height="484" loading="eager" decoding="async" />

      <div class="search-panel" role="search" aria-label="Global resource search preview">
        <div class="search-row">
          <span aria-hidden="true" class="prompt">&gt;</span>
          <span class="query">agent github review</span>
        </div>
        <div class="results" aria-label="Search result examples">
          {searchEntries.slice(0, 3).map((entry, i) => (
            <article class="result-row">
              <Badge tone={RESULT_ACCENT[i] ?? 'purple'}>{entry.label}</Badge>
              <div>
                <h3>{entry.title}</h3>
                <p>{entry.description.length > 100 ? `${entry.description.slice(0, 100)}…` : entry.description}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>

    <div class="resource-grid" aria-label="Resource categories">
      {resources.map((resource) => (
        <RetroResourceCard
          title={resource.title}
          label={resource.label}
          description={resource.description}
          href={resource.href}
          icon={SECTION_ICON_MAP[resource.icon] ?? resource.icon}
          accent={resource.accent}
        />
      ))}
    </div>
  </Container>
</section>

<style>
  .hero { border-bottom: 1px solid var(--color-border-soft); }
  .hero-console {
    position: relative;
    max-width: 1440px;
    min-height: 35rem;
    margin-inline: auto;
    overflow: auto;
    display: grid;
    align-content: center;
    gap: 1.75rem;
    border-bottom: 1px solid var(--color-border-soft);
    padding: clamp(2.25rem, 5vw, 3.5rem) clamp(1rem, 3vw, 2.5rem);
  }
  .hero-copy { max-width: 49rem; display: grid; gap: 1rem; z-index: 1; }
  .terminal-label {
    width: fit-content;
    margin: 0;
    border-radius: var(--radius-1);
    background: var(--color-yellow);
    color: var(--color-bg);
    padding: 0.25rem 0.5rem;
    font-size: 0.88rem;
    font-weight: 800;
  }
  h1 {
    max-width: 48.75rem;
    margin: 0;
    color: var(--color-text);
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 7vw, 4.8rem);
    font-weight: 800;
    letter-spacing: -0.055em;
    line-height: 1.03;
  }
  .lead {
    max-width: 48.75rem;
    margin: 0;
    color: var(--color-muted);
    font-size: clamp(1.05rem, 1.9vw, 1.15rem);
    line-height: 1.65;
  }
  .mascot {
    position: absolute;
    right: clamp(0rem, 2vw, 2.5rem);
    top: clamp(9.5rem, 13vw, 11.5rem);
    width: clamp(18rem, 27vw, 28rem);
    max-width: 48%;
    opacity: 0.9;
    image-rendering: pixelated;
  }
  .search-panel {
    z-index: 1;
    width: min(100%, 45rem);
    border: 1px solid var(--color-primary);
    border-radius: var(--radius-1);
    background: var(--color-bg);
    box-shadow: var(--shadow-primary);
    padding: 1.25rem;
  }
  .search-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-bottom: 0.8rem;
    font-size: clamp(1rem, 2vw, 1.15rem);
  }
  .prompt { color: var(--color-green); font-weight: 800; }
  .query { color: var(--color-text); }
  .results { display: grid; gap: 0.75rem; }
  .result-row {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 1rem;
    background: rgb(169 112 255 / 14%);
    padding: 0.85rem 1rem;
  }
  .result-row:nth-child(2) { background: rgb(45 140 255 / 14%); }
  .result-row:nth-child(3) { background: rgb(144 255 177 / 10%); }
  .result-row h3 {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.3;
  }
  .result-row p {
    margin: 0.25rem 0 0;
    color: var(--color-muted);
    font-size: 1rem;
  }
  .resource-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.25rem;
    max-width: 1440px;
    margin-inline: auto;
    padding-block: 2rem;
  }
  @media (max-width: 1100px) {
    .mascot { width: clamp(15rem, 42vw, 23rem); right: -4rem; top: 9rem; opacity: 0.18; }
    .resource-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 560px) {
    .hero-console { min-height: auto; padding-inline: 1rem; }
    .mascot { display: none; }
    .resource-grid { grid-template-columns: 1fr; }
    .result-row { grid-template-columns: 1fr; }
  }
</style>
