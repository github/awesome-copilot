---
/**
 * FAQ section — ported from awesome-copilot-jh base UI.
 *
 * Renders the accordion FAQ list with terminal kicker.
 */
import Accordion from '../ui/Accordion.astro';
import Container from '../ui/Container.astro';

const faqItems = [
  {
    question: 'What platforms do you support?',
    answer: 'We support GitHub Copilot on VS Code, Visual Studio, JetBrains IDEs, Neovim, and any editor that supports the Copilot extension. Our agents and instructions work across all platforms where Copilot runs.'
  },
  {
    question: 'Is there a free tier?',
    answer: 'Yes. The marketplace and all public resources are free to browse. Some advanced agents and private team instructions may require a subscription, but the core catalog is always open source.'
  },
  {
    question: 'Can I cancel anytime?',
    answer: 'Absolutely. There are no long-term contracts. You can cancel your subscription at any time from your account settings, and you will retain access until the end of your current billing period.'
  },
  {
    question: 'Do you offer refunds?',
    answer: 'We offer refunds within 14 days of purchase if you are not satisfied. Just contact support and we will process it — no questions asked.'
  },
  {
    question: 'How do I upgrade my plan?',
    answer: 'You can upgrade from your account dashboard at any time. The change takes effect immediately, and you will be charged a prorated amount for the remainder of the billing cycle.'
  }
];
---
<section class="faq-section" aria-labelledby="faq-title">
  <Container>
    <div class="faq-header">
      <p class="faq-kicker">$ cat ~/faq.md</p>
      <h2 id="faq-title">Frequently Asked Questions</h2>
      <p class="faq-subtitle">Got questions? We've got answers.</p>
    </div>
    <div class="faq-list" role="list">
      {faqItems.map((item, index) => (
        <Accordion question={item.question} answer={item.answer} index={index} />
      ))}
    </div>
  </Container>
</section>

<style>
  .faq-section {
    padding-block: 4rem 5rem;
    border-top: 1px solid var(--color-border-soft);
  }
  .faq-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .faq-kicker {
    margin: 0 0 0.75rem;
    color: var(--color-green);
    font-size: 0.88rem;
    font-weight: 800;
  }
  .faq-header h2 {
    margin: 0 0 0.6rem;
    color: var(--color-text);
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    letter-spacing: -0.045em;
    line-height: 1.06;
  }
  .faq-subtitle {
    margin: 0;
    color: var(--color-muted);
    font-size: clamp(0.9rem, 1.5vw, 1rem);
    line-height: 1.55;
  }
  .faq-list {
    max-width: 800px;
    margin-inline: auto;
  }
</style>
