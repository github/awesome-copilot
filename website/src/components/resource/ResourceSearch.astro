---
/**
 * Scoped search input for catalog pages.
 *
 * Wired by search-client.ts at runtime.  Works with the
 * `initSearch()` orchestrator for fuzzy search + URL sync.
 */
import Icon from '../ui/Icon.astro';

export interface Props {
  id?: string;
  placeholder?: string;
}

const {
  id = 'resource-search',
  placeholder = 'Search…',
} = Astro.props;
---
<div class="resource-search-bar">
  <span class="search-icon" aria-hidden="true">
    <Icon name="search" size={18} />
  </span>
  <input
    id={id}
    class="resource-search-input"
    type="search"
    placeholder={placeholder}
    autocomplete="off"
  />
  <div
    id={`${id}-status`}
    class="search-live-region"
    role="status"
    aria-live="polite"
    aria-atomic="true"
  ></div>
  <div
    id={`${id}-results`}
    class="search-results-dropdown"
    role="listbox"
    aria-label="Search results"
  ></div>
</div>

<style>
  .resource-search-bar {
    position: relative;
  }

  .search-icon {
    position: absolute;
    inset: 0 auto 0 0.85rem;
    display: flex;
    align-items: center;
    color: var(--color-muted);
    pointer-events: none;
  }

  .resource-search-input {
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2);
    background: var(--color-bg-elevated);
    padding: 0.8rem 1rem 0.8rem 2.7rem;
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.95rem;
    transition: border-color var(--motion-fast);
  }

  .resource-search-input::placeholder {
    color: var(--color-subtle);
  }

  .resource-search-input:focus {
    border-color: var(--color-primary);
    outline: none;
    box-shadow: var(--shadow-primary);
  }

  .resource-search-input::-webkit-search-cancel-button {
    display: none;
  }

  .search-live-region {
    margin-top: var(--space-2);
    font-size: 0.78rem;
    color: var(--color-muted);
    min-height: 1.2rem;
  }

  .search-results-dropdown {
    position: absolute;
    inset: 100% 0 auto;
    z-index: 5;
    max-height: 360px;
    overflow-y: auto;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2);
    background: var(--color-bg-elevated);
    box-shadow: var(--shadow-card);
    display: none;
  }
</style>
