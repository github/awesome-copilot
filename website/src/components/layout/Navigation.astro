---
import { primaryNav } from '../../config/nav';
import { SITE } from '../../config/site';
import BitButton from '../ui/8BitButton.astro';
import Icon from '../ui/Icon.astro';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="site-header">
  <a class="brand" href="/" aria-label={`${SITE.title} home`}>
    <span class="brand-mark" aria-hidden="true">
      <img src={SITE.favicon} alt="" width="28" height="28" />
    </span>
    <span class="brand-name">GitHub Copilot</span>
    <span class="brand-badge">Awesome</span>
  </a>

  <button
    class="menu-button"
    type="button"
    aria-expanded="false"
    aria-controls="primary-navigation"
  >
    <Icon name="menu" size={18} />
    <span class="sr-only">Open navigation</span>
  </button>

  <nav id="primary-navigation" class="nav" aria-label="Primary navigation">
    {
      primaryNav.map((item) => {
        const href = item.href.replace(/\/$/, '') || '/';
        const active = currentPath === href;
        return (
          <a
            class:list={['nav-link', { 'nav-link--active': active }]}
            href={item.href}
          >
            {active ? `$ ${item.label}` : item.label}
          </a>
        );
      })
    }
  </nav>

  <BitButton
    href="https://github.com/github/awesome-copilot"
    variant="secondary"
    size="sm"
    ariaLabel="Open GitHub repository"
  >
    <Icon name="github" size={16} />
    GITHUB ->
  </BitButton>
</header>

<script>
  const header = document.querySelector('.site-header');
  const button = header?.querySelector('.menu-button');
  const nav = header?.querySelector('#primary-navigation');

  button?.addEventListener('click', () => {
    const expanded = button.getAttribute('aria-expanded') === 'true';
    button.setAttribute('aria-expanded', String(!expanded));
    nav?.toggleAttribute('data-open', !expanded);
  });

  nav?.addEventListener('click', (event) => {
    if (event.target instanceof HTMLAnchorElement) {
      button?.setAttribute('aria-expanded', 'false');
      nav?.removeAttribute('data-open');
    }
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4.25rem;
    border-bottom: 1px solid var(--color-border-soft);
    background: rgb(10 13 13 / 88%);
    padding-inline: clamp(1rem, 2.4vw, 1.5rem);
    backdrop-filter: blur(16px);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    min-width: fit-content;
  }

  .brand-mark {
    display: flex;
    align-items: center;
    line-height: 0;
  }

  .brand-name {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .brand-badge {
    border-radius: var(--radius-1);
    background: var(--color-primary);
    color: var(--color-black);
    padding: 0.25rem 0.5rem;
    font-size: 0.88rem;
    font-weight: 800;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: clamp(0.85rem, 1.4vw, 1.35rem);
  }

  .nav-link {
    color: var(--color-muted);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1;
    transition: color var(--motion-fast);
  }

  .nav-link:hover,
  .nav-link--active {
    color: var(--color-green);
  }

  .menu-button {
    display: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-1);
    background: transparent;
    color: var(--color-text);
    padding: 0.55rem;
  }

  @media (max-width: 1100px) {
    .nav {
      position: absolute;
      inset: 4rem 1rem auto 1rem;
      display: none;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      border: 1px solid var(--color-border);
      border-radius: var(--radius-2);
      background: var(--color-bg-elevated);
      padding: 1rem;
      box-shadow: var(--shadow-card);
    }

    .nav[data-open] {
      display: grid;
    }

    .menu-button {
      display: inline-flex;
    }

    .site-header :global(.bit-btn) {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .brand-name {
      font-size: 1.08rem;
    }

    .brand-badge {
      display: none;
    }

    .nav {
      grid-template-columns: 1fr;
    }
  }
</style>
