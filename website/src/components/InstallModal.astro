---
export interface Props {
  resourceType: string;
}

const { resourceType } = Astro.props;
const label = resourceType;
---

<dialog
  id="install-modal"
  class="install-modal-dialog"
  aria-labelledby="install-modal-title"
  aria-modal="true"
>
  <div class="install-modal-panel pixel-panel">
    <div class="install-modal-header">
      <h2 id="install-modal-title" class="install-modal-title">Install in VS Code</h2>
      <button
        type="button"
        class="install-modal-close"
        id="install-modal-close"
        aria-label="Close dialog"
      >
        <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
          <path d="M3.72 3.72a.75.75 0 011.06 0L8 6.94l3.22-3.22a.75.75 0 111.06 1.06L9.06 8l3.22 3.22a.75.75 0 11-1.06 1.06L8 9.06l-3.22 3.22a.75.75 0 01-1.06-1.06L6.94 8 3.72 4.78a.75.75 0 010-1.06z"/>
        </svg>
      </button>
    </div>
    <p class="install-modal-desc">Choose your VS Code edition to install this {label}.</p>
    <div class="install-modal-actions">
      <a
        id="install-modal-vscode"
        class="btn btn-primary install-modal-btn"
        href="#"
      >
        <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
          <path d="M10.72 1.227a.75.75 0 011.06 0l.97.97a.75.75 0 010 1.06l-.97.97 2.22 2.22.97-.97a.75.75 0 011.06 0l.97.97a.75.75 0 010 1.06l-8.25 8.25a.75.75 0 01-1.06 0l-.97-.97-2.22 2.22-.97.97a.75.75 0 01-1.06 0l-.97-.97a.75.75 0 010-1.06l.97-.97-2.22-2.22-.97.97a.75.75 0 01-1.06 0l-.97-.97a.75.75 0 010-1.06l8.25-8.25z"/>
        </svg>
        VS Code
      </a>
      <a
        id="install-modal-insiders"
        class="btn btn-secondary install-modal-btn"
        href="#"
      >
        <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
          <path d="M10.72 1.227a.75.75 0 011.06 0l.97.97a.75.75 0 010 1.06l-.97.97 2.22 2.22.97-.97a.75.75 0 011.06 0l.97.97a.75.75 0 010 1.06l-8.25 8.25a.75.75 0 01-1.06 0l-.97-.97-2.22 2.22-.97.97a.75.75 0 01-1.06 0l-.97-.97a.75.75 0 010-1.06l.97-.97-2.22-2.22-.97.97a.75.75 0 01-1.06 0l-.97-.97a.75.75 0 010-1.06l8.25-8.25z"/>
        </svg>
        VS Code Insiders
      </a>
    </div>
  </div>
</dialog>

<style>
  .install-modal-dialog {
    border: none;
    padding: 0;
    background: transparent;
    max-width: 100%;
    width: 420px;
  }

  .install-modal-dialog::backdrop {
    background: rgba(0, 0, 0, 0.6);
  }

  .install-modal-dialog[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .install-modal-panel {
    position: relative;
    overflow: hidden;
    border: 4px solid var(--color-border-soft);
    border-radius: 0;
    background: var(--color-bg-elevated);
    box-shadow: 4px 4px 0 var(--color-black);
    padding: 24px;
    width: 100%;
  }

  .install-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  .install-modal-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
  }

  .install-modal-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: 2px solid var(--color-border-soft);
    background: var(--color-surface-1);
    color: var(--color-text);
    cursor: pointer;
    padding: 0;
  }

  .install-modal-close:hover {
    background: var(--color-surface-2);
  }

  .install-modal-desc {
    margin: 0 0 20px;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .install-modal-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .install-modal-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 16px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
  }

  .install-modal-btn svg {
    flex-shrink: 0;
  }
</style>

<script>
  (function() {
    const dialog = document.getElementById('install-modal') as HTMLDialogElement | null;
    const closeBtn = document.getElementById('install-modal-close');

    closeBtn?.addEventListener('click', () => dialog?.close());
    dialog?.querySelectorAll<HTMLAnchorElement>('.install-modal-btn').forEach((link) => {
      link.addEventListener('click', (e) => {
        if (!link.href.startsWith('vscode')) return;
        e.preventDefault();
        window.location.href = link.href;
      });
    });
    dialog?.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && dialog?.open) dialog.close();
    });
  })();
</script>
